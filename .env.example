# ============================================
# Razkindo ERP - Environment Variables Template
# Copy file ini ke .env dan isi sesuai konfigurasi
# ============================================

# --- Supabase (Wajib) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database Connection (Wajib) ---
# Pooler connection (app runtime)
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=30
# Direct connection (Prisma migrations)
DIRECT_URL=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:5432/postgres?connect_timeout=30
# Supabase DB URLs (for RPC deployment)
SUPABASE_DB_URL=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:5432/postgres?connect_timeout=30
SUPABASE_POOLER_URL=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=30

# --- Auth (Wajib - generate baru untuk production) ---
AUTH_SECRET=generate-dengan-openssl-rand-hex-32

# --- Moota (Opsional - untuk mutasi bank otomatis) ---
MOOTA_API_URL=https://app.moota.co/api/v2
MOOTA_PERSONAL_TOKEN=your-moota-token

# --- App Settings ---
NEXT_PUBLIC_APP_NAME=Razkindo ERP
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Server Settings ---
LOG_LEVEL=info

# --- STB Mode (jangan diubah - sudah true di docker-compose) ---
STB_MODE=true

# --- Push Notifications (Opsional - generate VAPID keys) ---
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@razkindo.com

# --- Email Notifications (Opsional - Resend) ---
# Daftar: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Razkindo ERP <noreply@yourdomain.com>

# --- QRIS Payment (Opsional - Tripay) ---
# Daftar: https://tripay.co.id
TRIPAY_API_KEY=your-tripay-api-key
TRIPAY_PRIVATE_KEY=your-tripay-private-key
TRIPAY_MERCHANT_CODE=your-merchant-code
TRIPAY_MODE=sandbox  # 'sandbox' untuk testing, 'production' untuk live
